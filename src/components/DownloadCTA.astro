---
/**
 * DownloadCTA — ArkenAge-style download section with file name + trust badges.
 */
import { t, type Locale } from '@/i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
---

<section class="py-24 md:py-36">
  <div class="container text-center">
    <h2 class="reveal text-[length:var(--font-size-h2)] font-bold mb-4">
      {locale === 'en' ? 'Get Started with MacSweep' : '开始使用 MacSweep'}
    </h2>

    <!-- System info -->
    <div class="reveal reveal-d1 flex items-center justify-center gap-3 text-sm text-[var(--color-text-secondary)] mb-10 flex-wrap">
      <span class="text-[var(--color-accent-purple)] font-mono border border-[rgba(139,92,246,0.3)] rounded-full px-3 py-0.5">v1.0.0</span>
      <span>·</span>
      <span>{locale === 'en' ? 'macOS 12 or later' : 'macOS 12 或更高版本'}</span>
      <span>·</span>
      <span>Apple Silicon & Intel</span>
    </div>

    <!-- Download button with file name -->
    <div class="reveal reveal-d2 mb-6">
      <a href="#" class="btn-download">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        {locale === 'en' ? 'Download MacSweep.dmg' : '下载 MacSweep.dmg'}
      </a>
    </div>

    <!-- Secondary links -->
    <div class="reveal reveal-d3 flex items-center justify-center gap-4 text-sm mb-8">
      <a href="#" class="text-[var(--color-accent-purple)] hover:underline">
        {locale === 'en' ? 'Release History' : '历史版本'}
      </a>
    </div>

    <!-- Trust badges -->
    <p class="reveal reveal-d4 text-sm text-[var(--color-text-muted)]">
      Developer ID {locale === 'en' ? 'Signed' : '签名'} · Apple {locale === 'en' ? 'Notarized' : '公证'} · {locale === 'en' ? 'Safe & Free' : '安全且免费'}
    </p>
  </div>
</section>
