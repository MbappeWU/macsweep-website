---
/**
 * SafetyBanner — "安全为先" section with SVG icons + colored tag badges.
 */
import { t, type Locale } from '@/i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props

const cards = [
  {
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    color: '#10B981', bg: 'rgba(16,185,129,0.12)',
    title: { en: 'Protected Paths', zh: '受保护路径' },
    desc: { en: 'System-critical directories are hardcoded as protected: /System, ~/.ssh, ~/Library/Keychains and more.', zh: '系统关键目录永不触碰：/System、~/.ssh、~/Library/Keychains 等核心路径硬编码保护' },
    tag: { en: 'Hardcoded', zh: '硬编码保护', color: '#10B981', border: 'rgba(16,185,129,0.3)' },
  },
  {
    icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16',
    color: '#F59E0B', bg: 'rgba(245,158,11,0.12)',
    title: { en: 'Trash-First Deletion', zh: '废纸篓优先' },
    desc: { en: 'Files are moved to Trash by default rather than permanently deleted. Recover anything within 30 days.', zh: '默认将文件移入废纸篓而非永久删除，30 天内可随时恢复' },
    tag: { en: 'Recoverable', zh: '可恢复', color: '#F59E0B', border: 'rgba(245,158,11,0.3)' },
  },
  {
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    color: '#3B82F6', bg: 'rgba(59,130,246,0.12)',
    title: { en: 'Complete Audit Log', zh: '完整日志' },
    desc: { en: 'Every cleanup operation is fully logged for post-hoc audit and review.', zh: '每次清理操作完整记录到日志文件，支持事后审计追溯' },
    tag: { en: 'Auditable', zh: '可审计', color: '#3B82F6', border: 'rgba(59,130,246,0.3)' },
  },
] as const
---

<section class="py-24 md:py-32 bg-[var(--color-bg-secondary)]">
  <div class="container">
    <h2 class="reveal text-[var(--font-size-h2)] font-bold text-center text-gradient-section mb-4">
      {t(locale, 'safety.title')}
    </h2>
    <p class="reveal reveal-d1 text-[var(--font-size-body-lg)] text-[var(--color-text-secondary)] text-center max-w-2xl mx-auto mb-16">
      {t(locale, 'safety.subtitle')}
    </p>

    <div class="grid md:grid-cols-3 gap-5">
      {cards.map((card, idx) => (
        <div class={`reveal reveal-d${idx + 1} glass-panel glass-card rounded-[var(--radius-lg)] p-6`}>
          <div class="icon-box mb-5" style={`background: ${card.bg};`}>
            <svg fill="none" viewBox="0 0 24 24" stroke={card.color} stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={card.icon} />
            </svg>
          </div>
          <h3 class="text-[var(--font-size-body-lg)] font-semibold mb-2">
            {card.title[locale]}
          </h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
            {card.desc[locale]}
          </p>
          <span class="tag-badge" style={`color: ${card.tag.color}; border-color: ${card.tag.border};`}>
            {card.tag[locale]}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
