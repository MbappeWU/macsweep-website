---
/**
 * Privacy — "隐私保护" 2×2 card grid with colored icons (ArkenAge-style).
 */
import { t, type Locale } from '@/i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props

const cards = [
  {
    color: '#EF4444', bg: 'rgba(239,68,68,0.12)',
    icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636',
    title: { en: 'Zero Data Collection', zh: '零数据收集' },
    desc: { en: 'No collection, no storage, no transmission of any personal information.', zh: '不收集、不存储、不传输任何个人信息或用户数据' },
  },
  {
    color: '#3B82F6', bg: 'rgba(59,130,246,0.12)',
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    title: { en: 'Local Scanning', zh: '本地扫描' },
    desc: { en: 'File scanning runs only on your device. Path info is never uploaded.', zh: '文件扫描仅在您的设备上执行，路径信息绝不上传' },
  },
  {
    color: '#8B5CF6', bg: 'rgba(139,92,246,0.12)',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    title: { en: 'No Telemetry', zh: '无遥测' },
    desc: { en: 'No analytics, no crash reports, no network calls. Fully offline.', zh: '无分析统计、无崩溃上报、无网络通信，完全离线运行' },
  },
  {
    color: '#F59E0B', bg: 'rgba(245,158,11,0.12)',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    title: { en: 'No Account Required', zh: '无需账户' },
    desc: { en: 'No registration or login. Download and use instantly. No identity data collected.', zh: '无需注册或登录，下载即用，不收集任何身份信息' },
  },
] as const
---

<section class="py-24 md:py-32">
  <div class="container">
    <h2 class="reveal text-[var(--font-size-h2)] font-bold text-center text-gradient-section mb-4">
      {t(locale, 'privacy.title')}
    </h2>
    <p class="reveal reveal-d1 text-[var(--font-size-body-lg)] text-[var(--color-text-secondary)] text-center max-w-2xl mx-auto mb-16">
      {t(locale, 'privacy.subtitle')}
    </p>

    <div class="grid sm:grid-cols-2 gap-5 max-w-3xl mx-auto">
      {cards.map((card, idx) => (
        <div class={`reveal reveal-d${idx + 1} glass-panel glass-card rounded-[var(--radius-lg)] p-6`}>
          <div class="icon-box mb-5" style={`background: ${card.bg};`}>
            <svg fill="none" viewBox="0 0 24 24" stroke={card.color} stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={card.icon} />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">{card.title[locale]}</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{card.desc[locale]}</p>
        </div>
      ))}
    </div>
  </div>
</section>
