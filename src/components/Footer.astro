---
/**
 * Footer — clean single-line (ArkenAge-style).
 */
import { t, localePath, type Locale } from '@/i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const year = new Date().getFullYear().toString()
---

<footer class="border-t border-[var(--color-border)] py-8">
  <div class="container flex flex-col sm:flex-row items-center justify-between gap-4">
    <!-- Brand -->
    <a href={localePath(locale, '/')} class="flex items-center gap-2 no-underline">
      <svg class="w-5 h-5 text-[var(--color-accent-purple)]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
      <span class="text-sm text-[var(--color-text-primary)] font-medium">MacSweep</span>
    </a>

    <!-- Links -->
    <div class="flex items-center gap-6 text-sm">
      <a href="#" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] no-underline">{t(locale, 'footer.privacy')}</a>
    </div>

    <!-- Copyright -->
    <p class="text-sm text-[var(--color-text-muted)]">
      Copyright 2024-{year} MacSweep. All rights reserved.
    </p>
  </div>
</footer>
