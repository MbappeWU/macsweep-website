---
/**
 * 中文下载页
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import { t } from '@/i18n/utils'

const locale = 'zh' as const

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'MacSweep',
  operatingSystem: 'macOS',
  applicationCategory: 'UtilitiesApplication',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CNY' },
  downloadUrl: 'https://macsweep.app/zh/download',
}

const steps = ['s1', 's2', 's3'] as const
---

<BaseLayout
  title={t(locale, 'meta.download.title')}
  description={t(locale, 'meta.download.description')}
  locale={locale}
  canonicalPath="/download"
  jsonLd={jsonLd}
>
  <section class="py-24 md:py-40">
    <div class="container text-center">
      <div class="flex justify-center mb-8">
        <img src={`${import.meta.env.BASE_URL}macsweep.svg`} alt="MacSweep" width="80" height="80" class="drop-shadow-lg" />
      </div>

      <h1 class="text-[length:var(--font-size-hero)] font-bold mb-4">
        {t(locale, 'downloadPage.title')}
      </h1>
      <p class="text-[length:var(--font-size-body-lg)] text-[var(--color-text-secondary)] max-w-lg mx-auto mb-8">
        {t(locale, 'downloadPage.subtitle')}
      </p>

      <a href="#" class="btn-primary text-lg px-10 py-4 mb-4 inline-flex">
        {t(locale, 'downloadPage.cta')}
      </a>
      <p class="text-sm text-[var(--color-text-muted)] mb-20">
        {t(locale, 'downloadPage.version')}
      </p>

      <div class="grid md:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <!-- System requirements -->
        <div class="glass-panel rounded-[var(--radius-lg)] p-6 text-left">
          <h2 class="font-semibold mb-4">{t(locale, 'downloadPage.req.title')}</h2>
          <ul class="space-y-2 text-sm text-[var(--color-text-secondary)]">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[var(--color-accent-green)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {t(locale, 'downloadPage.req.os')}
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[var(--color-accent-green)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {t(locale, 'downloadPage.req.arch')}
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[var(--color-accent-green)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {t(locale, 'downloadPage.req.size')}
            </li>
          </ul>
        </div>

        <!-- Installation steps -->
        <div class="glass-panel rounded-[var(--radius-lg)] p-6 text-left">
          <h2 class="font-semibold mb-4">{t(locale, 'downloadPage.steps.title')}</h2>
          <ol class="space-y-3 text-sm text-[var(--color-text-secondary)]">
            {steps.map((step, idx) => (
              <li class="flex items-start gap-3">
                <span class="shrink-0 w-6 h-6 rounded-full bg-[var(--color-accent-purple)]/15 text-[var(--color-accent-purple)] text-xs font-semibold flex items-center justify-center">
                  {idx + 1}
                </span>
                {t(locale, `downloadPage.steps.${step}`)}
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
