---
/**
 * Hero — full-width gradient hero with app mockup (ArkenAge-level quality).
 */
import { t, localePath, type Locale } from '@/i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
---

<section class="relative overflow-hidden pt-32 pb-16 md:pt-44 md:pb-24">
  <!-- Gradient background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a103a] via-[var(--color-bg-primary)] to-[var(--color-bg-primary)]"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[700px] bg-[radial-gradient(ellipse,rgba(139,92,246,0.12),transparent_70%)]"></div>
  </div>

  <div class="container text-center">
    <!-- Version badge -->
    <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--color-border-hover)] bg-[var(--color-surface-glass)] mb-8">
      <span class="text-[var(--color-accent-purple)] font-mono text-sm font-medium">v1.0.0</span>
      <span class="w-px h-3 bg-[var(--color-border-hover)]"></span>
      <span class="text-sm text-[var(--color-text-secondary)]">macOS 12+</span>
    </div>

    <!-- Headline -->
    <h1 class="reveal reveal-d1 font-bold leading-[1.1] max-w-3xl mx-auto mb-5">
      <span class="text-gradient-section block text-[clamp(48px,6vw,72px)]">MacSweep</span>
    </h1>
    <p class="reveal reveal-d1 text-[var(--font-size-h2)] font-bold text-[var(--color-text-primary)] max-w-2xl mx-auto mb-5 leading-tight">
      {t(locale, 'hero.headline')}
    </p>

    <!-- Sub-headline -->
    <p class="reveal reveal-d2 text-[var(--font-size-body-lg)] text-[var(--color-text-secondary)] max-w-xl mx-auto mb-10 leading-relaxed">
      {t(locale, 'hero.subheadline')}
    </p>

    <!-- CTAs with icons -->
    <div class="reveal reveal-d3 flex flex-col sm:flex-row items-center justify-center gap-4 mb-4">
      <a href={localePath(locale, '/download')} class="btn-primary">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        {locale === 'en' ? 'Free Download DMG' : '免费下载 DMG'}
      </a>
      <a href="https://github.com/macsweep" target="_blank" rel="noopener noreferrer" class="btn-secondary">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        {locale === 'en' ? 'View Source' : '查看源码'}
      </a>
    </div>

    <!-- System requirements -->
    <p class="reveal reveal-d3 text-sm text-[var(--color-text-muted)] mb-16">
      {locale === 'en' ? 'Compatible with macOS 12 Monterey and later · Apple Silicon & Intel' : '兼容 macOS 12 Monterey 及以上 · Apple Silicon & Intel'}
    </p>

    <!-- App mockup (CSS-only macOS window) -->
    <div class="reveal reveal-d4 max-w-4xl mx-auto">
      <div class="macos-window">
        <div class="macos-titlebar">
          <div class="traffic-light" style="background:#FF5F57;"></div>
          <div class="traffic-light" style="background:#FEBC2E;"></div>
          <div class="traffic-light" style="background:#28C840;"></div>
        </div>
        <div class="flex min-h-[320px] md:min-h-[420px]">
          <!-- Sidebar -->
          <div class="w-[200px] shrink-0 border-r border-[rgba(255,255,255,0.05)] p-4 hidden md:block">
            <div class="flex items-center gap-2 mb-5">
              <img src="/macsweep.svg" alt="" width="20" height="20" />
              <span class="text-sm font-medium text-[var(--color-text-primary)]">MacSweep</span>
            </div>
            <p class="text-[10px] font-semibold tracking-wider text-[var(--color-text-muted)] uppercase mb-2">General</p>
            <div class="bg-[rgba(139,92,246,0.12)] rounded-lg px-3 py-2 mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-[var(--color-accent-purple)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              <span class="text-xs text-[var(--color-accent-purple)] font-medium">{locale === 'en' ? 'Smart Scan' : '智能扫描'}</span>
            </div>
            <p class="text-[10px] font-semibold tracking-wider text-[var(--color-text-muted)] uppercase mb-2">Cleanup</p>
            {[
              { icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4', name: locale === 'en' ? 'System Cache' : '系统缓存' },
              { icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16', name: locale === 'en' ? 'App Leftovers' : '应用残留' },
              { icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4', name: locale === 'en' ? 'Large Files' : '大文件' },
              { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', name: locale === 'en' ? 'Dev Junk' : '开发者垃圾' },
              { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', name: locale === 'en' ? 'Log Files' : '日志文件' },
              { icon: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4', name: locale === 'en' ? 'Downloads' : '下载管理' },
            ].map(item => (
              <div class="flex items-center gap-2 px-3 py-1.5 rounded-md hover:bg-[rgba(255,255,255,0.03)] mb-0.5">
                <svg class="w-3.5 h-3.5 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={item.icon} /></svg>
                <span class="text-xs text-[var(--color-text-secondary)]">{item.name}</span>
              </div>
            ))}
            <p class="text-[10px] font-semibold tracking-wider text-[var(--color-text-muted)] uppercase mt-4 mb-2">Analyze</p>
            <div class="flex items-center gap-2 px-3 py-1.5 rounded-md mb-0.5">
              <svg class="w-3.5 h-3.5 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
              <span class="text-xs text-[var(--color-text-secondary)]">{locale === 'en' ? 'Storage Map' : '存储地图'}</span>
            </div>
          </div>
          <!-- Main content area -->
          <div class="flex-1 flex flex-col items-center justify-center p-8">
            <h2 class="text-2xl md:text-3xl font-bold mb-2">{locale === 'en' ? 'Smart Scan' : '智能扫描'}</h2>
            <p class="text-sm text-[var(--color-text-secondary)] mb-8">{locale === 'en' ? 'Detect cleanable space on your Mac' : '全面检测 Mac 可清理空间'}</p>
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-full border-2 border-[rgba(139,92,246,0.25)] flex items-center justify-center mb-8 relative">
              <div class="absolute inset-0 rounded-full bg-[radial-gradient(circle,rgba(139,92,246,0.12),transparent_70%)]"></div>
              <div class="flex flex-col items-center gap-1">
                <svg class="w-8 h-8 text-[var(--color-text-primary)]" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                <span class="text-xs text-[var(--color-text-secondary)]">{locale === 'en' ? 'Start Scan' : '开始扫描'}</span>
              </div>
            </div>
            <div class="flex gap-3 flex-wrap justify-center">
              <div class="glass-panel rounded-lg px-4 py-3 text-center min-w-[100px]">
                <svg class="w-5 h-5 text-[var(--color-text-muted)] mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <p class="text-xs text-[var(--color-text-muted)]">{locale === 'en' ? 'Not scanned' : '从未扫描'}</p>
              </div>
              <div class="glass-panel rounded-lg px-4 py-3 text-center min-w-[100px] border-[rgba(139,92,246,0.2)]">
                <svg class="w-5 h-5 text-[var(--color-accent-purple)] mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
                <p class="text-sm font-semibold">79% {locale === 'en' ? 'Used' : '已用'}</p>
                <p class="text-[10px] text-[var(--color-text-muted)]">Macintosh HD</p>
              </div>
              <div class="glass-panel rounded-lg px-4 py-3 text-center min-w-[100px]">
                <svg class="w-5 h-5 text-[var(--color-accent-green)] mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                <p class="text-xs text-[var(--color-accent-green)]">{locale === 'en' ? 'Protected' : '安全保护已启用'}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
