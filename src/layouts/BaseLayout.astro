---
/**
 * BaseLayout — HTML shell wrapping every page.
 * Injects BaseHead, Header, Footer, and optional JSON-LD.
 */
import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import '@/styles/global.css'
import type { Locale } from '@/i18n/utils'

interface Props {
  title: string
  description: string
  locale: Locale
  canonicalPath: string
  ogImage?: string
  jsonLd?: Record<string, unknown>
}

const { title, description, locale, canonicalPath, ogImage, jsonLd } = Astro.props
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <BaseHead
      title={title}
      description={description}
      locale={locale}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
    />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <Header locale={locale} currentPath={canonicalPath} />
    <main class="pt-16">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
